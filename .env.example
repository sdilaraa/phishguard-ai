# PhishGuard AI environment variables

# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5223

# Database
POSTGRES_DB=phishguard_db
POSTGRES_USER=phishguard_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SECRET=change_this_secret_key
JWT_ISSUER=PhishGuardAI
JWT_AUDIENCE=PhishGuardAIUsers

# Optional LLM integration
LLM_PROVIDER=
LLM_API_KEY=

# Optional Redis
REDIS_HOST=localhost
REDIS_PORT=6379
